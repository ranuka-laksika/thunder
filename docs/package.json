{
  "private": true,
  "name": "@thunder/docs",
  "version": "0.0.0",
  "description": "Documentation for ⚡️ Thunder",
  "author": "WSO2",
  "license": "Apache-2.0",
  "homepage": "https://github.com/asgardeo/thunder/tree/main/docs#readme",
  "bugs": {
    "url": "https://github.com/asgardeo/thunder/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/asgardeo/thunder"
  },
  "keywords": [
    "asgardeo",
    "thunder",
    "docs",
    "documentation",
    "wso2"
  ],
  "scripts": {
    "build": "pnpm prebuild && docusaurus build",
    "clear": "docusaurus clear",
    "deploy": "docusaurus deploy",
    "dev": "pnpm prebuild && docusaurus start --port 5180",
    "docusaurus": "docusaurus",
    "generate:api-specs": "node ./scripts/merge-openapi-specs.mjs",
    "generate:changelog": "node ./scripts/generate-changelog.mjs",
    "prebuild": "node ./scripts/prebuild.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "serve": "docusaurus serve",
    "swizzle": "docusaurus swizzle",
    "typecheck": "tsc",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids"
  },
  "dependencies": {
    "@docusaurus/core": "3.9.2",
    "@docusaurus/plugin-content-docs": "3.9.2",
    "@docusaurus/preset-classic": "3.9.2",
    "@mdx-js/react": "3.0.0",
    "@thunder/eslint-plugin-thunder": "workspace:^",
    "@thunder/logger": "workspace:^",
    "@thunder/prettier-config": "workspace:^",
    "@wso2/oxygen-ui": "catalog:",
    "@wso2/oxygen-ui-icons-react": "catalog:",
    "@scalar/api-reference-react": "0.9.15",
    "clsx": "catalog:",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "prism-react-renderer": "2.3.0",
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "3.9.2",
    "@docusaurus/tsconfig": "3.9.2",
    "@docusaurus/types": "3.9.2",
    "typescript": "catalog:",
    "yaml": "2.8.2"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  }
}
