{
  "private": true,
  "name": "@thunder/frontend",
  "version": "0.0.0",
  "description": "Frontend workspace for ⚡️ Thunder",
  "author": "WSO2",
  "license": "Apache-2.0",
  "type": "module",
  "homepage": "https://github.com/asgardeo/thunder/tree/main/frontend#readme",
  "bugs": {
    "url": "https://github.com/asgardeo/thunder/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/asgardeo/thunder"
  },
  "keywords": [
    "asgardeo",
    "thunder",
    "frontend",
    "workspace",
    "wso2"
  ],
  "scripts": {
    "build": "nx run-many --target=build --all",
    "build:apps": "nx run-many --target=build --projects=apps/*",
    "build:docs": "pnpm run build:packages && node ./scripts/build-docs.js",
    "build:packages": "nx run-many --target=build --projects=packages/*",
    "clean": "nx run-many --target=clean --all",
    "i18n:extract": "pnpm i18next-cli sync",
    "format:check": "prettier --check --cache .",
    "format:fix": "prettier --write --cache .",
    "lint": "nx run-many --target=lint --all --parallel",
    "lint:fix": "nx run-many --target=fix:lint --all --parallel",
    "test": "nx run-many --target=test --all --parallel",
    "typecheck": "nx run-many --target=typecheck --all --parallel"
  },
  "devDependencies": {
    "@thunder/eslint-plugin-thunder": "workspace:^",
    "@thunder/logger": "workspace:^",
    "@thunder/prettier-config": "workspace:^",
    "eslint": "catalog:",
    "i18next-cli": "^1.51.3",
    "nx": "22.6.2",
    "prettier": "catalog:",
    "rimraf": "catalog:",
    "tslib": "catalog:",
    "typescript": "catalog:"
  },
  "pnpm": {
    "overrides": {
      "flatted": ">=3.4.0",
      "picomatch": ">=4.0.4",
      "vite": "catalog:",
      "nx>axios": ">=1.13.5",
      "dompurify": ">=3.3.2",
      "minimatch@>=5.0.0 <5.1.8": ">=5.1.8",
      "minimatch@<3.1.4": ">=3.1.4",
      "serialize-javascript": ">=7.0.3",
      "yaml": ">=1.10.3",
      "path-to-regexp": ">=0.1.13",
      "svgo": ">=3.3.3",
      "ajv": "6.14.0",
      "brace-expansion@>=4.0.0 <5.0.5": ">=5.0.5",
      "lodash": ">=4.18.1"
    },
    "packageExtensions": {
      "@hookform/resolvers": {
        "peerDependencies": {
          "zod": "*"
        }
      }
    }
  }
}
